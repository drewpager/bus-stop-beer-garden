---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');
events.sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

function formatDate(dateStr: string) {
  const date = new Date(dateStr + 'T12:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="Events">
  <div class="bg-[#2D5016] py-16 px-4 text-center">
    <h1 class="text-[#FCC200] text-5xl font-extrabold mb-3">Events</h1>
    <p class="text-yellow-200/80 text-lg max-w-xl mx-auto">Live music, trivia, plant swaps, and more. Something's always happening at the Stop.</p>
  </div>

  <section class="max-w-4xl mx-auto px-4 py-16">
    {events.length === 0 ? (
      <p class="text-center text-gray-500">No upcoming events. Check back soon!</p>
    ) : (
      <div class="space-y-6">
        {events.map(event => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:border-[#FCC200] hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col sm:flex-row">
            <!-- Date badge -->
            <div class="bg-[#2D5016] text-[#FCC200] flex flex-col items-center justify-center px-6 py-6 min-w-[100px] sm:min-w-[120px] text-center">
              <span class="text-3xl font-extrabold leading-none">
                {new Date(event.data.date + 'T12:00:00').getDate()}
              </span>
              <span class="text-xs font-semibold uppercase tracking-wider mt-1">
                {new Date(event.data.date + 'T12:00:00').toLocaleDateString('en-US', { month: 'short' })}
              </span>
              <span class="text-yellow-200/70 text-xs mt-1">
                {new Date(event.data.date + 'T12:00:00').getFullYear()}
              </span>
            </div>

            <!-- Event details -->
            <div class="p-6 flex-1">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <h2 class="text-xl font-bold text-[#2D5016]">{event.data.title}</h2>
                <span class="text-sm font-medium text-[#FCC200] bg-[#2D5016]/10 px-3 py-1 rounded-full whitespace-nowrap">
                  {event.data.time}
                </span>
              </div>
              <p class="text-sm text-gray-500 mb-2">{formatDate(event.data.date)}</p>
              <p class="text-gray-700 leading-relaxed">{event.data.description}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <div class="max-w-4xl mx-auto px-4 pb-16 text-center">
    <p class="text-gray-500 text-sm">Events are free unless noted. Follow <a href="https://instagram.com/beerbusstop" target="_blank" rel="noopener noreferrer" class="text-[#2D5016] hover:underline">@beerbusstop</a> for the latest updates.</p>
  </div>
</Layout>
