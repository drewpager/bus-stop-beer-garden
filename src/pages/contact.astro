---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const stops = await getCollection('stops');
const mainStop = stops[0];
---

<Layout title="Contact">
  <div class="bg-[#2D5016] py-16 px-4 text-center">
    <h1 class="text-[#FCC200] text-5xl font-extrabold mb-3">Say Hello</h1>
    <p class="text-yellow-200/80 text-lg max-w-xl mx-auto">Questions, feedback, or just want to chat? We'd love to hear from you.</p>
  </div>

  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-[#2D5016] mb-6">Contact Info</h2>

          <div class="space-y-5">
            {mainStop && (
              <>
                <div class="flex items-start gap-4">
                  <div class="bg-[#2D5016] rounded-full p-2.5 shrink-0">
                    <svg class="w-5 h-5 text-[#FCC200]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900">Address</p>
                    <p class="text-gray-600">{mainStop.data.address}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="bg-[#2D5016] rounded-full p-2.5 shrink-0">
                    <svg class="w-5 h-5 text-[#FCC200]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900">Hours</p>
                    <p class="text-gray-600 whitespace-pre-line">{mainStop.data.hours.split(', ').join('\n')}</p>
                  </div>
                </div>

                <div class="flex items-center gap-4">
                  <div class="bg-[#2D5016] rounded-full p-2.5 shrink-0">
                    <svg class="w-5 h-5 text-[#FCC200]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900">Phone</p>
                    <a href={`tel:${mainStop.data.phone.replace(/\D/g,'')}`} class="text-[#2D5016] hover:underline">{mainStop.data.phone}</a>
                  </div>
                </div>

                <div class="flex items-center gap-4">
                  <div class="bg-[#2D5016] rounded-full p-2.5 shrink-0">
                    <svg class="w-5 h-5 text-[#FCC200]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-gray-900">Email</p>
                    <a href={`mailto:${mainStop.data.email}`} class="text-[#2D5016] hover:underline">{mainStop.data.email}</a>
                  </div>
                </div>
              </>
            )}

            <div class="flex items-center gap-4">
              <div class="bg-[#2D5016] rounded-full p-2.5 shrink-0">
                <svg class="w-5 h-5 text-[#FCC200]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Instagram</p>
                <a href="https://instagram.com/beerbusstop" target="_blank" rel="noopener noreferrer" class="text-[#2D5016] hover:underline">@beerbusstop</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Map Placeholder -->
      <div>
        <h2 class="text-2xl font-bold text-[#2D5016] mb-6">Find Us</h2>
        <div
          class="w-full h-80 rounded-2xl bg-gradient-to-br from-[#2D5016]/10 via-[#3a6b1e]/15 to-[#FCC200]/10 flex flex-col items-center justify-center border-2 border-dashed border-[#2D5016]/20"
          aria-label="Map placeholder"
        >
          <svg class="w-14 h-14 text-[#2D5016]/30 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <p class="text-[#2D5016]/50 font-medium">Map placeholder</p>
          {mainStop && <p class="text-gray-400 text-sm mt-1">{mainStop.data.address}</p>}
          <p class="text-gray-400 text-xs mt-2">Google Maps embed goes here</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
