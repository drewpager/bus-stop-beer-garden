---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const plants = await getCollection('plants');
plants.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Layout title="Gardens">
  <div class="bg-[#2D5016] py-16 px-4 text-center">
    <h1 class="text-[#FCC200] text-5xl font-extrabold mb-3">The Garden</h1>
    <p class="text-yellow-200/80 text-lg max-w-xl mx-auto">Succulents, cacti, and plants to take a piece of the Stop home with you.</p>
  </div>

  <section class="max-w-7xl mx-auto px-4 py-16">
    {plants.length === 0 ? (
      <p class="text-center text-gray-500">Plants are all sold out! Check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {plants.map(plant => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-[#2D5016] transition-all duration-200 overflow-hidden">
            <!-- Plant illustration placeholder -->
            <div class="h-40 bg-gradient-to-br from-[#2D5016]/10 via-[#3a6b1e]/15 to-[#FCC200]/10 flex items-center justify-center">
              <span class="text-5xl" aria-hidden="true">🌿</span>
            </div>
            <div class="p-5">
              <h2 class="text-lg font-bold text-[#2D5016] mb-2">{plant.data.name}</h2>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{plant.data.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-2xl font-extrabold text-[#2D5016]">${plant.data.price}</span>
                <span class="text-xs bg-[#2D5016]/10 text-[#2D5016] px-2 py-1 rounded-full font-medium">In Stock</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <div class="max-w-7xl mx-auto px-4 pb-16 text-center">
    <p class="text-gray-500 text-sm">Plant availability changes weekly. Visit us in person to see the full selection.</p>
  </div>
</Layout>
