---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const stops = await getCollection('stops');
---

<Layout title="Stops">
  <div class="bg-[#2D5016] py-16 px-4 text-center">
    <h1 class="text-[#FCC200] text-5xl font-extrabold mb-3">Our Stop</h1>
    <p class="text-yellow-200/80 text-lg max-w-xl mx-auto">Come hang. We saved you a seat.</p>
  </div>

  <section class="max-w-5xl mx-auto px-4 py-16 space-y-12">
    {stops.length === 0 ? (
      <p class="text-center text-gray-500">Location info coming soon.</p>
    ) : (
      stops.map(stop => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <!-- Map Placeholder -->
          <div
            class="w-full h-64 bg-gradient-to-br from-[#2D5016]/20 to-[#FCC200]/20 flex items-center justify-center"
            aria-label="Map placeholder"
          >
            <div class="text-center text-gray-500">
              <svg class="w-12 h-12 mx-auto mb-2 text-[#2D5016]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <p class="text-sm font-medium text-[#2D5016]/60">Google Maps embed</p>
              <p class="text-xs text-gray-400 mt-1">{stop.data.address}</p>
              {/* To enable: replace this div with a Google Maps iframe */}
            </div>
          </div>

          <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h2 class="text-2xl font-bold text-[#2D5016] mb-4">{stop.data.name}</h2>
              <p class="text-gray-700 leading-relaxed mb-4">{stop.data.description}</p>

              <div class="space-y-2 text-sm">
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 text-[#2D5016] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <span class="text-gray-700">{stop.data.address}</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-[#2D5016] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                  <a href={`tel:${stop.data.phone.replace(/\D/g,'')}`} class="text-gray-700 hover:text-[#2D5016]">{stop.data.phone}</a>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-[#2D5016] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                  <a href={`mailto:${stop.data.email}`} class="text-gray-700 hover:text-[#2D5016]">{stop.data.email}</a>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-bold text-[#2D5016] mb-4">Hours</h3>
              <div class="bg-[#2D5016]/5 rounded-xl p-4 space-y-2">
                {stop.data.hours.split(', ').map((line: string) => {
                  const [days, hours] = line.split(' ');
                  return (
                    <div class="flex justify-between text-sm">
                      <span class="font-medium text-[#2D5016]">{days}</span>
                      <span class="text-gray-700">{hours}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      ))
    )}
  </section>
</Layout>
