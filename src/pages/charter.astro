---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Charter the Bus">
  <div class="bg-[#2D5016] py-16 px-4 text-center">
    <h1 class="text-[#FCC200] text-5xl font-extrabold mb-3">Rent the Bus</h1>
    <p class="text-yellow-200/80 text-lg max-w-xl mx-auto">Make your next event unforgettable. The Bus Stop is available for private parties, corporate events, birthdays, and more.</p>
  </div>

  <!-- Perks -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      {[
        { icon: '🍺', title: 'Full Bar Service', desc: 'Full tap selection and cocktails staffed by our bartenders.' },
        { icon: '🌿', title: 'Garden Setting', desc: 'String lights, lush greenery, and an unforgettable atmosphere.' },
        { icon: '🎶', title: 'Music Ready', desc: 'PA system available. Bring your playlist or book a live act.' },
      ].map(perk => (
        <div class="text-center bg-[#2D5016]/5 rounded-xl p-6">
          <div class="text-4xl mb-3">{perk.icon}</div>
          <h3 class="font-bold text-[#2D5016] text-lg mb-2">{perk.title}</h3>
          <p class="text-gray-600 text-sm">{perk.desc}</p>
        </div>
      ))}
    </div>

    <!-- Form -->
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <h2 class="text-2xl font-bold text-[#2D5016] mb-6">Request a Charter</h2>

      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
        <input type="hidden" name="access_key" value="efb63498-161a-4e5c-92cf-f9abff1a7027" />
        <input type="hidden" name="subject" value="New Charter Request - Bus Stop Beer Garden" />
        <input type="hidden" name="from_name" value="Bus Stop Beer Garden Website" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name <span class="text-red-500">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5016] focus:border-transparent"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5016] focus:border-transparent"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="event_date" class="block text-sm font-medium text-gray-700 mb-1">Event Date <span class="text-red-500">*</span></label>
            <input
              type="date"
              id="event_date"
              name="event_date"
              required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5016] focus:border-transparent"
            />
          </div>
          <div>
            <label for="headcount" class="block text-sm font-medium text-gray-700 mb-1">Expected Headcount <span class="text-red-500">*</span></label>
            <input
              type="number"
              id="headcount"
              name="headcount"
              required
              min="1"
              max="200"
              placeholder="50"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5016] focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Tell Us About Your Event</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Type of event, special requests, questions..."
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5016] focus:border-transparent resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-[#2D5016] text-[#FCC200] font-bold py-3 px-6 rounded-lg text-base hover:bg-[#3a6b1e] transition-colors focus:outline-none focus:ring-2 focus:ring-[#FCC200] focus:ring-offset-2"
        >
          Send Charter Request
        </button>

        <p class="text-xs text-gray-400 text-center">We'll get back to you within 24 hours.</p>
      </form>
    </div>
  </section>
</Layout>
