---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: `${base}/menu`, label: 'Menu' },
  { href: `${base}/stops`, label: 'Stops' },
  { href: `${base}/gardens`, label: 'Gardens' },
  { href: `${base}/events`, label: 'Events' },
  { href: `${base}/charter`, label: 'Charter' },
  { href: `${base}/contact`, label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Bus Stop Beer Garden</title>
  <meta name="description" content="Bus Stop Beer Garden — Cold Beer. Fresh Plants. Good Vibes. Austin, TX." />
</head>
<body class="bg-white text-gray-900 font-sans">

  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-[#2D5016] shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href={base || '/'} class="flex items-center gap-3 group">
          <!-- SVG Bus Logo -->
          <svg width="48" height="28" viewBox="0 0 48 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Bus body -->
            <rect x="2" y="4" width="40" height="18" rx="3" fill="#FCC200"/>
            <!-- Front cab -->
            <rect x="38" y="6" width="7" height="12" rx="2" fill="#FCC200"/>
            <!-- Windows -->
            <rect x="6" y="7" width="7" height="6" rx="1" fill="#2D5016"/>
            <rect x="16" y="7" width="7" height="6" rx="1" fill="#2D5016"/>
            <rect x="26" y="7" width="7" height="6" rx="1" fill="#2D5016"/>
            <!-- Front window -->
            <rect x="40" y="8" width="4" height="5" rx="1" fill="#2D5016"/>
            <!-- Door -->
            <rect x="34" y="14" width="4" height="7" rx="1" fill="#2D5016"/>
            <!-- Wheels -->
            <circle cx="10" cy="23" r="4" fill="#2D5016"/>
            <circle cx="10" cy="23" r="2" fill="#FCC200"/>
            <circle cx="34" cy="23" r="4" fill="#2D5016"/>
            <circle cx="34" cy="23" r="2" fill="#FCC200"/>
            <!-- Bumper -->
            <rect x="2" y="21" width="5" height="3" rx="1" fill="#2D5016"/>
          </svg>
          <span class="text-[#FCC200] font-bold text-lg leading-tight hidden sm:block group-hover:text-yellow-300 transition-colors">
            Bus Stop<br/><span class="text-sm font-normal">Beer Garden</span>
          </span>
        </a>

        <!-- Desktop Nav Links -->
        <div class="hidden md:flex items-center gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-[#FCC200] hover:bg-[#FCC200] hover:text-[#2D5016] px-3 py-2 rounded-md text-sm font-medium transition-colors duration-150"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden text-[#FCC200] hover:text-yellow-300 p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-[#FCC200]"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-[#1e3810] border-t border-[#FCC200]/20">
      <div class="px-4 py-3 space-y-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="block text-[#FCC200] hover:bg-[#FCC200] hover:text-[#2D5016] px-3 py-2 rounded-md text-base font-medium transition-colors duration-150"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[#2D5016] text-[#FCC200] mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Brand -->
        <div>
          <h3 class="font-bold text-xl mb-2">Bus Stop Beer Garden</h3>
          <p class="text-yellow-200/80 text-sm">Cold Beer. Fresh Plants. Good Vibes.</p>
          <p class="text-yellow-200/80 text-sm mt-1">Austin, TX</p>
        </div>

        <!-- Nav Links -->
        <div>
          <h4 class="font-semibold mb-3 text-[#FCC200]">Explore</h4>
          <ul class="space-y-1">
            {navLinks.map(link => (
              <li>
                <a href={link.href} class="text-yellow-200/80 hover:text-[#FCC200] text-sm transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Social & Contact -->
        <div>
          <h4 class="font-semibold mb-3 text-[#FCC200]">Follow Along</h4>
          <a
            href="https://instagram.com/beerbusstop"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-yellow-200/80 hover:text-[#FCC200] text-sm transition-colors mb-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            @beerbusstop
          </a>
          <p class="text-yellow-200/80 text-sm">123 School Bus Lane<br/>Austin, TX 78701</p>
        </div>
      </div>

      <div class="border-t border-[#FCC200]/20 mt-8 pt-6 text-center">
        <p class="text-yellow-200/60 text-sm">&copy; 2026 Bus Stop Beer Garden. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    toggle?.addEventListener('click', () => {
      const isOpen = !mobileMenu?.classList.contains('hidden');
      mobileMenu?.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  </script>
</body>
</html>
